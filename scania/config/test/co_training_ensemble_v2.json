          "max_epochs": 1,
          "patience": 5,
          "rul_target_standardization": true
        }
      },
      {
        "transformer_features": {
          "model_params": {
            "transformer_encoder_head_num": 8,
            "transformer_num_layer": 2,
            "fc_layer_dim": 128,
