  },
  "training_params": {
    "lr": 0.0002,
    "patience": 50,
    "max_epochs": 1,
    "rul_target_standardization": true
  },
  "model_params": {
    "transformer_encoder_head_num": 8,
    "hidden_dim": 256,
    "lstm_num_layers": 5,
    "lstm_dropout": 0.3,
    "fc_layer_dim": 128,
    "fc_dropout": 0.2
  }
}
