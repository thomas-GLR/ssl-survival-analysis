{
  "dataset_params": {
    "sequence_len": 32,
    "seed": 42,
    "data_fraction": 1.0,
    "val_rate": 0.2,
    "test_rate": 0.1,
    "stratify": true,
    "norm_type": "z-score",
    "num_workers": 4,
    "pin_memory": true,
    "return_sequence_label": false,
    "batch_size": 128,
    "shuffle_loader": true,
    "counter_mode": "cumulative",
    "include_histograms": false,
    "histogram_mode": "sum"
  },
  "training_params": {
    "lr": 0.0002,
    "patience": 50,
    "max_epochs": 500,
    "rul_target_standardization": true
  },
  "model_params": {
    "hidden_dim": 256,
    "lstm_num_layers": 3,
    "lstm_dropout": 0.3,
    "fc_layer_dim": 128,
    "fc_dropout": 0.2
  }
}
