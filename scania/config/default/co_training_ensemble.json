{
  "dataset_params": {
    "sequence_len": 32,
    "seed": 42,
    "val_rate": 0.2,
    "test_rate": 0.1,
    "stratify": true,
    "norm_type": "z-score",
    "num_workers": 4,
    "pin_memory": true,
    "return_sequence_label": false,
    "batch_size": 256,
    "shuffle_loader": true,
    "counter_mode": "both"
  },
  "model_params": {
    "models": [
      {
        "cnn": {
          "model_params": {},
          "lr": 0.0002,
          "max_epochs": 500,
          "patience": 50,
          "rul_target_standardization": true
        }
      },
      {
        "lstm": {
          "model_params": {
            "hidden_dim": 256,
            "lstm_num_layers": 3,
            "lstm_dropout": 0.3,
            "fc_layer_dim": 128,
            "fc_dropout": 0.2
          },
          "lr": 0.0002,
          "max_epochs": 500,
          "patience": 50,
          "rul_target_standardization": true
        }
      },
      {
        "transformer_features": {
          "model_params": {
            "transformer_encoder_head_num": 8,
            "transformer_num_layer": 2,
            "fc_layer_dim": 128,
            "fc_dropout": 0.2
          },
          "lr": 0.0002,
          "max_epochs": 500,
          "patience": 50,
          "rul_target_standardization": true
        }
      },
      {
        "transformer_time_sequence": {
          "model_params": {
            "transformer_encoder_head_num": 8,
            "transformer_num_layer": 2,
            "fc_layer_dim": 128,
            "fc_dropout": 0.2
          },
          "lr": 0.0002,
          "max_epochs": 500,
          "patience": 50,
          "rul_target_standardization": true
        }
      }
    ]
  },
  "training_params": {
    "iterations": 10,
    "suspension_pool_size": 0.1,
    "add_ratio": 0.05,
    "is_fine_tuning_during_finding_best_suspension_data": true,
    "is_fine_tuning_for_last_step": false,
    "fine_tune_lr_factor": 0.1,
    "fine_tune_max_epochs": 10,
    "inference_batch_size": 1024
